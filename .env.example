# ─────────────────────────────────────────────────────────────────────────────
# Vespeiro — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# All variables are optional for local development — sensible defaults apply.
#
# ── Database ─────────────────────────────────────────────────────────────────

# Supabase project URL for production database writes (scraped articles, stats).
# Leave empty to use the SQLite fallback for local development.
# Required by: supabase client, scrape/analyze/backup workflows
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SQLAlchemy database connection string.
# Default: sqlite+aiosqlite:///data/vespeiro.db (local SQLite file)
# For production, use a PostgreSQL connection string instead:
#   postgresql+asyncpg://user:password@host:5432/vespeiro
DATABASE_URL=sqlite+aiosqlite:///data/vespeiro.db

# ── Scraping ─────────────────────────────────────────────────────────────────

# Google Custom Search API credentials (DRE scraper).
# Free tier: 100 queries/day — sufficient for weekly DRE appointment checks.
# Get a key: https://console.cloud.google.com/apis/credentials
#   → Create API key → restrict to "Custom Search API"
# Get a CX:  https://programmablesearchengine.google.com/
#   → Add a search engine → copy the "cx" value
# Required by: DRE spider (dre_appointments, dre_general_appointments)
# GOOGLE_API_KEY=AIzaSy...
# GOOGLE_CUSTOM_SEARCH_CX=0123456789abcdef

# ── Telegram Alerts (Jornal do Contra) ──────────────────────────────────────

# Telegram bot token for sending daily briefings and anomaly alerts.
# Create a bot: https://t.me/BotFather → /newbot → copy the token.
# Required by: run_alert.py, stats.yml workflow
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram chat/group ID where alerts are sent.
# Get your chat ID: send a message to the bot, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Required by: run_alert.py, stats.yml workflow
# TELEGRAM_CHAT_ID=-1234567890

# ── NLP / ML ────────────────────────────────────────────────────────────────

# Embedding model for narrative similarity comparisons (HuggingFace model ID).
# Default: intfloat/multilingual-e5-large (supports Portuguese)
# Change to a smaller model if memory-constrained:
#   sentence-transformers/all-MiniLM-L6-v2 (English-only, fast)
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── Logging ──────────────────────────────────────────────────────────────────

# Python logging level.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Scraping Cadence ────────────────────────────────────────────────────────

# Minimum scrape interval in minutes (rate limiting guard).
SCRAPE_INTERVAL_MINUTES=15

# ── GitHub Actions (set these as repo secrets, not in .env) ──────────────────
#
# These are configured in GitHub → Settings → Secrets and Variables → Actions:
#
#   SUPABASE_URL
#   SUPABASE_SERVICE_KEY
#   GOOGLE_API_KEY
#   GOOGLE_CUSTOM_SEARCH_CX
#   TELEGRAM_BOT_TOKEN
#   TELEGRAM_CHAT_ID
#
# Workflows that use them:
#   - scrape.yml       → SUPABASE_URL, SUPABASE_SERVICE_KEY, GOOGLE_*
#   - analyze.yml      → (env vars from .env file committed in repo)
#   - stats.yml        → TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID
#   - backup.yml       → SUPABASE_URL, SUPABASE_SERVICE_KEY
#   - deploy-dashboard.yml → (no secrets needed — static site)
