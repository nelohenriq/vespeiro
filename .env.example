# Supabase (production database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Local dev (SQLite fallback)
# Nota: corre todos os comandos da raiz do projeto (vespeiro/)
# para que este path relativo funcione corretamente
DATABASE_URL=sqlite+aiosqlite:///data/vespeiro.db

# Telegram bot (optional alerts — for Phase 4)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
